# CE50 environment variables
# Copy to .env.local (or .env) at repo root and fill in real values.
# Loader: server/config.py reads .env.local then .env from repo root.

# --- Backend (server/config.py) ---
# SQLite database file path
DB_PATH=server/ce50.db
# Image upload directory
UPLOAD_DIR=server/image
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000
# JWT signing secret (REQUIRED — server refuses to start if unset or default).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-random-64-hex-chars

# --- GNews integration (optional, leaves external news disabled if blank) ---
GNEWS_API_KEY=
GNEWS_QUERY=AI Chip OR Semiconductor
GNEWS_SYNC_INTERVAL_HOURS=12

# --- Frontend (Next.js) ---
# Backend API URL the browser hits. Baked into the JS bundle at build time.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend API URL for server-side fetches (SSR + route handlers).
# Only needed under docker compose, where the web container reaches the API via
# Docker DNS (http://api:8000) — localhost would point at Next itself. compose
# sets this automatically; leave unset for local dev.
API_INTERNAL_URL=http://api:8000
